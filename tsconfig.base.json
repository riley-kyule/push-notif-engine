{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@epe/shared": ["packages/shared/src/index.ts"],
      "@epe/shared/*": ["packages/shared/src/*"],
      "@epe/types": ["packages/types/src/index.ts"],
      "@epe/types/*": ["packages/types/src/*"],
      "@epe/ui": ["packages/ui/src/index.ts"],
      "@epe/ui/*": ["packages/ui/src/*"]
    }
  }
}
