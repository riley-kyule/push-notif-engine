DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/exotic_push_engine
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
PORT=3001
CORS_ORIGINS=http://127.0.0.1:3000
PUBLIC_API_BASE_URL=http://127.0.0.1:3001/api

# Campaign media storage
# Default: local filesystem storage on the VM.
CAMPAIGN_MEDIA_STORAGE_BACKEND=local
CAMPAIGN_MEDIA_STORAGE_ROOT=storage/campaign-media

# Optional S3-compatible storage if you later add Cloudflare R2 or a similar service.
# CAMPAIGN_MEDIA_STORAGE_BACKEND=s3
# CAMPAIGN_MEDIA_STORAGE_BUCKET=epe-campaign-media
# CAMPAIGN_MEDIA_STORAGE_REGION=auto
# CAMPAIGN_MEDIA_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# CAMPAIGN_MEDIA_STORAGE_ACCESS_KEY_ID=replace-with-r2-key
# CAMPAIGN_MEDIA_STORAGE_SECRET_ACCESS_KEY=replace-with-r2-secret
# CAMPAIGN_MEDIA_STORAGE_FORCE_PATH_STYLE=true

# Backup Config — full system backups (DB + media) to Dropbox / Google Drive.
# Generate with: openssl rand -base64 32. Encrypts the stored OAuth refresh tokens at rest.
BACKUP_TOKEN_ENCRYPTION_KEY=replace-with-base64-32-bytes

# Shared by the API and worker. Generate once with `openssl rand -base64 32`;
# changing or losing it makes encrypted VAPID private keys unreadable.
VAPID_KEY_ENCRYPTION_KEY=replace-with-base64-32-bytes

# Optional HMAC secret for CRM delivery callbacks. When set, callbacks include
# `X-EPE-Signature: sha256=<hex digest of the raw request body>`.
CRM_CALLBACK_SIGNING_SECRET=replace-with-a-long-random-string

# Dashboard-triggered production updates. Docker mode writes only an allowlisted
# request file; the host-side epe-docker-updater service owns Git and Docker.
EPE_DEPLOYMENT_MODE=docker
EPE_DEPLOYMENT_REQUEST_DIR=/deployment
EPE_ENABLE_DEPLOYMENT_ACTIONS=true

# Dropbox: create an app at https://www.dropbox.com/developers/apps (Scoped access,
# "Full Dropbox" or "App folder"), add files.content.write to its permissions, and set
# this exact redirect URI in the app's settings.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=https://your-dashboard-domain/api/dashboard/backup/dropbox/callback

# Google OAuth: create an OAuth 2.0 Client ID (type "Web application") at
# https://console.cloud.google.com/apis/credentials, enable the Drive API for backups
# and the Sheets API for analytics exports, and reuse the same client for Google
# sign-in. Add every redirect URI used by EPE as an authorized redirect URI on this
# client (backup OAuth callback, analytics export callback, dashboard SSO callback).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-dashboard-domain/api/dashboard/backup/google-drive/callback

# Separate redirect URI for the "Export to Google Sheets" analytics action — same
# OAuth client as above, but requests Sheets write access instead of Drive, so Google
# requires its own registered redirect URI.
GOOGLE_SHEETS_OAUTH_REDIRECT_URI=https://your-dashboard-domain/api/dashboard/analytics/export/google-sheets/callback
