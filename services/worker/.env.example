# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/exotic_push_engine

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Optional provider configuration
APNS_ISSUER_ID=
APNS_KEY_ID=
APNS_TEAM_ID=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Public API base used by browser push acknowledgements from service workers.
BROWSER_PUSH_ACK_BASE_URL=http://127.0.0.1:3001/api

# How many push-relay HTTP calls run concurrently per campaign send job. Higher values
# send a campaign faster but use more file descriptors and DB connections at once —
# raise the OS ulimit -n and the worker's Postgres pool size (services/worker/src/bootstrap.ts)
# together if you push this much higher. Production should set this explicitly.
BROWSER_PUSH_SEND_CONCURRENCY=25
# Concurrent BullMQ campaign jobs. Keep this at 1 on the current single worker
# until delivery metrics show that the host and provider egress have headroom.
BROWSER_PUSH_QUEUE_CONCURRENCY=1
# Abort and retry the whole BullMQ job after this many transient provider/network
# failures, preventing a DNS outage from becoming thousands of failed deliveries.
BROWSER_PUSH_TRANSIENT_FAILURE_THRESHOLD=10
MOBILE_PUSH_SEND_CONCURRENCY=200
MOBILE_PUSH_QUEUE_CONCURRENCY=1
MOBILE_PUSH_TRANSIENT_FAILURE_THRESHOLD=10

# Must exactly match the API value.
VAPID_KEY_ENCRYPTION_KEY=replace-with-base64-32-bytes
