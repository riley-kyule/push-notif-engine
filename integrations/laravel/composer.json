{
  "name": "epe/laravel-starter",
  "description": "Laravel starter package for Exotic Push Engine.",
  "type": "library",
  "license": "proprietary",
  "autoload": {
    "psr-4": {
      "EPE\\LaravelStarter\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "EPE\\LaravelStarter\\EpePushServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "symfony/http-foundation": "^6.0 || ^7.0"
  }
}
